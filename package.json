{
  "name": "bubble-hex-arcade",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "install:ci": "npm ci",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vite",
    "build": "vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "node --experimental-strip-types --test tests/cheats.test.ts tests/content.test.ts tests/levels.test.ts tests/physics.test.ts tests/audio.test.ts tests/scoring.test.ts tests/run-rng.test.ts tests/hex-cards.test.ts tests/campaign.test.ts tests/run-state.test.ts tests/results.test.ts tests/campaign-map.test.ts tests/progression-difficulty.test.ts && npm run build && node --test tests/rendered-html.test.mjs",
    "validate:artifact": "node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "bash scripts/sites-env.sh -- drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module",
  "displayName": "BUBBLE HEX"
}
